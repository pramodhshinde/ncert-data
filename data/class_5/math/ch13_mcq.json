  {"mcq_id":"c5m_ch13_q01","chapter_id":"c5m_ch13","question":"What is 24 × 12?","options":["248","268","288","308"],"correct_index":2,"explanation":"24 × 12 = 24 × 10 + 24 × 2 = 240 + 48 = 288.","ncert_page":143,"difficulty":"easy","subject":"Math"},
  {"mcq_id":"c5m_ch13_q02","chapter_id":"c5m_ch13","question":"Which is an easier way to multiply 36 × 5?","options":["36 × 5 = 36 × 4 + 36","36 × 5 = 36 × 10 ÷ 2","36 × 5 = 30 × 5 + 5","36 × 5 = 36 + 5 × 5"],"correct_index":1,"explanation":"Multiplying by 5 is same as multiplying by 10 then dividing by 2: 36 × 10 = 360, 360 ÷ 2 = 180.","ncert_page":144,"difficulty":"medium","subject":"Math"},
  {"mcq_id":"c5m_ch13_q03","chapter_id":"c5m_ch13","question":"What is 144 ÷ 12?","options":["10","11","12","13"],"correct_index":2,"explanation":"144 ÷ 12 = 12 (since 12 × 12 = 144).","ncert_page":145,"difficulty":"easy","subject":"Math"},
  {"mcq_id":"c5m_ch13_q04","chapter_id":"c5m_ch13","question":"To multiply 25 × 16, one strategy is:","options":["25 × 4 × 4","25 × 8 × 2","25 × 4 × 4 = 100 × 4","Both b and c"],"correct_index":2,"explanation":"25 × 16 = 25 × 4 × 4 = 100 × 4 = 400. This is a quick mental strategy.","ncert_page":146,"difficulty":"hard","subject":"Math"},
  {"mcq_id":"c5m_ch13_q05","chapter_id":"c5m_ch13","question":"What is 50 × 18?","options":["800","850","900","950"],"correct_index":2,"explanation":"50 × 18 = 50 × 20 − 50 × 2 = 1000 − 100 = 900.","ncert_page":147,"difficulty":"medium","subject":"Math"},
  {"mcq_id":"c5m_ch13_q06","chapter_id":"c5m_ch13","question":"256 ÷ 8 = ?","options":["28","32","36","42"],"correct_index":1,"explanation":"256 ÷ 8 = 32 (since 8 × 32 = 256).","ncert_page":147,"difficulty":"easy","subject":"Math"},
  {"mcq_id":"c5m_ch13_q07","chapter_id":"c5m_ch13","question":"If 15 × 4 = 60, then 15 × 8 = ?","options":["75","90","120","150"],"correct_index":2,"explanation":"15 × 8 = 15 × 4 × 2 = 60 × 2 = 120.","ncert_page":148,"difficulty":"easy","subject":"Math"},
  {"mcq_id":"c5m_ch13_q08","chapter_id":"c5m_ch13","question":"A box holds 24 books. How many books in 15 boxes?","options":["250","310","360","420"],"correct_index":2,"explanation":"24 × 15 = 24 × 10 + 24 × 5 = 240 + 120 = 360 books.","ncert_page":148,"difficulty":"medium","subject":"Math"},
  {"mcq_id":"c5m_ch13_q09","chapter_id":"c5m_ch13","question":"What is the remainder when 100 is divided by 7?","options":["1","2","3","4"],"correct_index":0,"explanation":"100 ÷ 7 = 14 remainder 2. Wait: 7 × 14 = 98, 100 − 98 = 2. Remainder = 2.","ncert_page":149,"difficulty":"medium","subject":"Math"},
