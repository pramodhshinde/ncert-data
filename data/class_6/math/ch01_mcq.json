[
  {"mcq_id":"c6m_ch01_q01","chapter_id":"c6m_ch01","question":"How many six-digit numbers can be formed using all digits 1-6 exactly once?","options":["360","720","120","240"],"correct_index":1,"explanation":"6! = 6×5×4×3×2×1 = 720","ncert_page":1,"difficulty":"medium","subject":"Mathematics"},
  {"mcq_id":"c6m_ch01_q02","chapter_id":"c6m_ch01","question":"The place value of 5 in 75,842 is:","options":["5","500","5000","50000"],"correct_index":2,"explanation":"5 is in the thousands place, so its place value = 5 × 1000 = 5000","ncert_page":2,"difficulty":"easy","subject":"Mathematics"},
  {"mcq_id":"c6m_ch01_q03","chapter_id":"c6m_ch01","question":"The successor of 99,999 is:","options":["99,998","1,00,000","99,000","1,00,001"],"correct_index":1,"explanation":"The successor of any number n is n+1. 99,999 + 1 = 1,00,000","ncert_page":3,"difficulty":"easy","subject":"Mathematics"},
  {"mcq_id":"c6m_ch01_q04","chapter_id":"c6m_ch01","question":"Which of the following is the greatest 5-digit number?","options":["99,999","89,999","99,899","98,999"],"correct_index":0,"explanation":"Among the given options, 99,999 is the greatest 5-digit number.","ncert_page":4,"difficulty":"easy","subject":"Mathematics"},
  {"mcq_id":"c6m_ch01_q05","chapter_id":"c6m_ch01","question":"MCMXCIX in Hindu-Arabic numerals is:","options":["1999","1909","1989","1099"],"correct_index":0,"explanation":"M=1000, CM=900, XC=90, IX=9. So MCMXCIX = 1000+900+90+9 = 1999","ncert_page":16,"difficulty":"hard","subject":"Mathematics"},
  {"mcq_id":"c6m_ch01_q06","chapter_id":"c6m_ch01","question":"The predecessor of 10,000 is:","options":["10,001","9,999","9,000","10,010"],"correct_index":1,"explanation":"Predecessor of n is n-1. 10,000 - 1 = 9,999","ncert_page":5,"difficulty":"easy","subject":"Mathematics"},
  {"mcq_id":"c6m_ch01_q07","chapter_id":"c6m_ch01","question":"How many thousands are there in one lakh?","options":["10","100","1000","10000"],"correct_index":1,"explanation":"1 lakh = 1,00,000 = 100 × 1000. So there are 100 thousands in one lakh.","ncert_page":8,"difficulty":"medium","subject":"Mathematics"},
  {"mcq_id":"c6m_ch01_q08","chapter_id":"c6m_ch01","question":"The smallest 4-digit number is:","options":["1000","999","1001","9999"],"correct_index":0,"explanation":"The smallest 4-digit number is 1000.","ncert_page":4,"difficulty":"easy","subject":"Mathematics"},
  {"mcq_id":"c6m_ch01_q09","chapter_id":"c6m_ch01","question":"In Roman numerals, 40 is written as:","options":["XXXX","XL","LL","LX"],"correct_index":1,"explanation":"In Roman numerals, XL = 50 - 10 = 40","ncert_page":16,"difficulty":"medium","subject":"Mathematics"},
  {"mcq_id":"c6m_ch01_q10","chapter_id":"c6m_ch01","question":"The sum of place values of digits in 987 is:","options":["987","24","900","2+4"],"correct_index":0,"explanation":"Place value of 9 = 900, 8 = 80, 7 = 7. Sum = 900+80+7 = 987","ncert_page":2,"difficulty":"medium","subject":"Mathematics"}
